# Configuration SMTP pour l'envoi d'emails
# Copiez ce fichier vers .env et remplissez vos vraies valeurs
ENVIRONMENT=development

PORT=5001

# Serveur SMTP (exemple: smtp.gmail.com, smtp.outlook.com, etc.)
SMTP_SERVER=smtp.gmail.com

# Port SMTP (587 pour TLS, 465 pour SSL)
SMTP_PORT=587

# Nom d'utilisateur SMTP (généralement votre email)
SMTP_USERNAME=your-email@gmail.com

# Mot de passe SMTP (utilisez un "mot de passe d'application" pour Gmail)
SMTP_PASSWORD=your-app-password

# Email expéditeur (généralement le même que SMTP_USERNAME)
FROM_EMAIL=your-email@gmail.com

# Email de destination pour recevoir les messages de contact
TO_EMAIL=sem_phares@yahoo.com
